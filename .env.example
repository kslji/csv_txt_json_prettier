# Comma-separated list of allowed frontend origins, or "*" for any (not
# recommended in production once you have a real frontend domain).
FMT_CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Requests-per-window rate limit per client IP, e.g. "60/minute", "500/hour"
FMT_RATE_LIMIT=60/minute

# Max accepted input size in MB
FMT_MAX_INPUT_MB=5

FMT_ENVIRONMENT=production
